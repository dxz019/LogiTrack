PORT=5000
DATABASE_URL=postgresql://user:pass@localhost:5432/logitrack
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Google Maps - Enable: Maps JS, Directions, Geocoding, Routes, Places
GOOGLE_MAPS_API_KEY=your_key
GOOGLE_MAPS_SERVER_KEY=your_key

# OpenAI
OPENAI_API_KEY=your_key

# Firebase Cloud Messaging
FCM_SERVER_KEY=your_firebase_key

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@email.com
SMTP_PASS=your_app_password

# AWS S3 (optional - for delivery proof photos)
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=

# Database
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/logitrack

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate strong random strings)
JWT_SECRET=your_strong_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_strong_refresh_secret_here_min_32_chars

# Other configuration...
