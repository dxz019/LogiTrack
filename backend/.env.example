PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/logitrack
REDIS_URL=redis://localhost:6379

JWT_SECRET=your_strong_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_strong_refresh_secret_here_min_32_chars

CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Google Maps API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key

# OpenAI (for AI features)
OPENAI_API_KEY=your_openai_key

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your_firebase_key

# Email SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@email.com
SMTP_PASS=your_app_password